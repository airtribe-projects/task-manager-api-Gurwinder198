{
  "info": {
    "name": "Task Manager API",
    "description": "Task Manager REST API - all endpoints and key error cases. Set the {{baseUrl}} variable (default http://localhost:3000). Start the server with `npm start` first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "baseUrl", "value": "http://localhost:3000" }],
  "item": [
    {
      "name": "Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "Create task (valid)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Write docs\",\n  \"description\": \"Finish the README\",\n  \"completed\": false\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] }
      }
    },
    {
      "name": "Create task (with priority)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Ship release\",\n  \"description\": \"cut v1\",\n  \"completed\": false,\n  \"priority\": \"high\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] }
      }
    },
    {
      "name": "List all tasks",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] }
      }
    },
    {
      "name": "List tasks - filter completed=true",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks?completed=true",
          "host": ["{{baseUrl}}"],
          "path": ["tasks"],
          "query": [{ "key": "completed", "value": "true" }]
        }
      }
    },
    {
      "name": "List tasks - filter completed=false",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks?completed=false",
          "host": ["{{baseUrl}}"],
          "path": ["tasks"],
          "query": [{ "key": "completed", "value": "false" }]
        }
      }
    },
    {
      "name": "List tasks - sort by createdAt desc",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks?sort=-createdAt",
          "host": ["{{baseUrl}}"],
          "path": ["tasks"],
          "query": [{ "key": "sort", "value": "-createdAt" }]
        }
      }
    },
    {
      "name": "List tasks - paginate",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks?page=1&limit=5",
          "host": ["{{baseUrl}}"],
          "path": ["tasks"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "5" }
          ]
        }
      }
    },
    {
      "name": "List tasks by priority (high)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks/priority/high",
          "host": ["{{baseUrl}}"],
          "path": ["tasks", "priority", "high"]
        }
      }
    },
    {
      "name": "Get task by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks/1",
          "host": ["{{baseUrl}}"],
          "path": ["tasks", "1"]
        }
      }
    },
    {
      "name": "Update task (PUT - full replace)",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Set up environment\",\n  \"description\": \"Install tooling\",\n  \"completed\": true,\n  \"priority\": \"high\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/tasks/1",
          "host": ["{{baseUrl}}"],
          "path": ["tasks", "1"]
        }
      }
    },
    {
      "name": "Update task (PATCH - partial)",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"completed\": true\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/tasks/1",
          "host": ["{{baseUrl}}"],
          "path": ["tasks", "1"]
        }
      }
    },
    {
      "name": "Delete task",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks/2",
          "host": ["{{baseUrl}}"],
          "path": ["tasks", "2"]
        }
      }
    },
    {
      "name": "Error - task not found (404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks/999",
          "host": ["{{baseUrl}}"],
          "path": ["tasks", "999"]
        }
      }
    },
    {
      "name": "Error - unknown route (404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/nope", "host": ["{{baseUrl}}"], "path": ["nope"] }
      }
    },
    {
      "name": "Error - empty title (400)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"\",\n  \"description\": \"d\",\n  \"completed\": false\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] }
      }
    },
    {
      "name": "Error - empty description (400)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Valid title\",\n  \"description\": \"\",\n  \"completed\": false\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] }
      }
    },
    {
      "name": "Error - missing fields (400)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Valid title\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] }
      }
    },
    {
      "name": "Error - completed not boolean (400)",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Valid title\",\n  \"description\": \"d\",\n  \"completed\": \"true\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/tasks/1",
          "host": ["{{baseUrl}}"],
          "path": ["tasks", "1"]
        }
      }
    },
    {
      "name": "Error - invalid priority value (400)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Bad prio\",\n  \"description\": \"d\",\n  \"completed\": false,\n  \"priority\": \"urgent\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] }
      }
    },
    {
      "name": "Error - invalid priority level on route (400)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks/priority/urgent",
          "host": ["{{baseUrl}}"],
          "path": ["tasks", "priority", "urgent"]
        }
      }
    },
    {
      "name": "Error - malformed JSON body (400)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"title\": \"broken\", ",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] }
      }
    }
  ]
}
