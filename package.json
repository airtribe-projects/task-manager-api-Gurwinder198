{
  "name": "task-manager",
  "version": "1.0.0",
  "description": "Task Manager REST API (Express, in-memory storage)",
  "main": "app.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"*.js\"",
    "test:unit": "jest --runInBand",
    "pretest": "node -e \"if (process.version.slice(1).split('.')[0] < 18) { console.error('Unsupported Node.js version, please use version 18'); process.exit(1); }\"",
    "test": "tap test/*.js --disable-coverage"
  },
  "author": "Airtribe",
  "license": "ISC",
  "engines": {
    "node": ">= 18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.2",
    "supertest": "^6.3.4",
    "tap": "^18.6.1"
  }
}
